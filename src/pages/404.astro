---
import Layout from "../layouts/Layout.astro"
---

<Layout title="Page not found" description="The requested page was not found.">
  <section class="not-found-page">
    <div class="wrapper">
      <div class="meta-text meta-text--accent">404</div>
      <h1>Page not found</h1>
      <p>The route is not in the index. Head back home or send a note.</p>
      <div class="home-hero__actions">
        <a href="/" class="foundry-button foundry-button--primary">Back to homepage</a>
        <a href="/contact" class="foundry-button">Contact</a>
      </div>
    </div>
  </section>
</Layout>
